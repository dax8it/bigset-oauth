# BigSet local development environment
# Copy to .env and edit values for your setup.

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
# openrouter = original BigSet path: OpenRouter for LLMs + TinyFish for web.
# hermes     = local-first path: Hermes Agent for LLM + web, normally backed by
#              OpenAI Codex / ChatGPT OAuth configured inside Hermes.
LLM_PROVIDER_MODE=hermes

# -----------------------------------------------------------------------------
# Hermes mode
# -----------------------------------------------------------------------------
# Must match API_SERVER_KEY in the active Hermes profile env file.
HERMES_API_KEY=replace-this-local-secret

# Docker containers reach the host-side Hermes gateway through host.docker.internal.
# If running backend directly on the host, use http://127.0.0.1:8642/v1 instead.
HERMES_BASE_URL=http://host.docker.internal:8642/v1

# Cosmetic model id sent to Hermes. Hermes chooses its real provider/model from
# its own config, e.g. provider=openai-codex and model=gpt-5.5.
HERMES_MODEL=hermes-agent

# Conservative local defaults for agentic Codex/Hermes calls.
HERMES_CHAT_TIMEOUT_MS=180000
HERMES_DISCOVERY_TIMEOUT_MS=120000
HERMES_RESEARCH_TIMEOUT_MS=480000
HERMES_MAX_CONCURRENT=2
HERMES_MAX_ROWS=25
HERMES_BATCH_MAX_ROWS=10
HERMES_MAX_CANDIDATES_PER_ROUND=15

# -----------------------------------------------------------------------------
# Original OpenRouter + TinyFish mode
# -----------------------------------------------------------------------------
# Required only when LLM_PROVIDER_MODE=openrouter.
OPENROUTER_API_KEY=
TINYFISH_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SCHEMA_INFERENCE_MODEL=anthropic/claude-sonnet-4.6
POPULATE_ORCHESTRATOR_MODEL=qwen/qwen3.7-max
INVESTIGATE_SUBAGENT_MODEL=qwen/qwen3.7-max

# -----------------------------------------------------------------------------
# Local Docker / Convex / backend
# -----------------------------------------------------------------------------
PROD=
CLIENT_ORIGIN=http://localhost:3500
PORT=3501
CONVEX_URL=http://convex:3210
NEXT_PUBLIC_CONVEX_URL=http://localhost:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=

# make dev auto-fills these if blank/missing.
LOCAL_KEYCHAIN_PORT=3502
LOCAL_KEYCHAIN_TIMEOUT_MS=5000
LOCAL_KEYCHAIN_TOKEN=
BIGSET_LOCAL_WORKSPACE_ID=

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# Local dev can run without Clerk by leaving PROD unset. Production needs Clerk.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=https://local-mode.invalid

# -----------------------------------------------------------------------------
# Optional services
# -----------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=BigSet <noreply@example.com>

# Optional script-based client report delivery. These are not used by the app
# automatically; they are consumed by scripts/send-dataset-report.py.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=
EMAIL_SUBJECT=BigSet dataset report
EMAIL_ATTACHMENT=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
REFRESH_SCHEDULER_ENABLED=true
REFRESH_SCHEDULER_POLL_MS=60000
REFRESH_SCHEDULER_BATCH_SIZE=5
REFRESH_SCHEDULER_STALE_AFTER_MS=21600000
